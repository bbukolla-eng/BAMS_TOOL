# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-to-a-random-64-char-string
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bams
POSTGRES_USER=bams
POSTGRES_PASSWORD=bams_dev_password
DATABASE_URL=postgresql+asyncpg://bams:bams_dev_password@localhost:5432/bams

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Object Storage (MinIO / S3) ───────────────────────────────────────────────
STORAGE_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=bams
STORAGE_USE_SSL=false
# Set to true and fill AWS creds for production S3
USE_S3=false

# ── Anthropic Claude API ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=4096

# ── ML Models ─────────────────────────────────────────────────────────────────
ML_MODELS_PATH=./ml_models
YOLO_CONFIDENCE_THRESHOLD=0.45
YOLO_IOU_THRESHOLD=0.45
EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2

# ── ODA File Converter (DWG → DXF) ───────────────────────────────────────────
ODA_CONVERTER_PATH=/usr/local/bin/OdaFileConverter
# Download from: https://www.opendesign.com/guestfiles/oda_file_converter

# ── Email (optional, for notifications) ──────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@bams.ai
